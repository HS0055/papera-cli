{
  "name": "papera",
  "version": "0.2.0",
  "description": "Turn any AI chat — or your terminal — into a real, structured, editable Papera notebook. CLI + MCP server + SDK.",
  "type": "module",
  "bin": {
    "papera": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "papera",
    "mcp",
    "model-context-protocol",
    "ai",
    "notebook",
    "cli",
    "sdk",
    "claude",
    "chatgpt",
    "codex",
    "trackers",
    "planner"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HS0055/papera-cli.git"
  },
  "homepage": "https://papera.io",
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "~5.8.2"
  }
}
